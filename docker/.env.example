MYSQL_ROOT_PASSWORD=change_root_password
DB_USERNAME=aistock
DB_PASSWORD=change_app_password
DB_NAME=ai_stock

MYSQL_PORT=3306
BACKEND_PORT=8000
FRONTEND_PORT=8080

APP_DEBUG=false
TUSHARE_ENABLED=false
TUSHARE_TOKEN=

# Optional mirrors for users in mainland China.
# These speed up apt/pip/npm/apk downloads inside Docker builds.
# Base image pulls still require Docker Desktop / Docker daemon registry mirrors.
APT_MIRROR=https://mirrors.aliyun.com/debian
ALPINE_MIRROR=https://mirrors.aliyun.com/alpine
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
NPM_REGISTRY=https://registry.npmmirror.com
